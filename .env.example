# Copy to .env and adjust for your environment.

# Database (PostgreSQL in production recommended)
DATABASE_URL=sqlite:///./second_brain.db

# CORS: comma-separated origins allowed to call the API (include your SPA origin)
CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:8000,http://localhost:8000

# Which seeded user the API treats as signed-in (see database seed emails)
# priya@greenhope.org — NGO demo (grants, volunteers, impact, flashcards)
# rahul@webcraftzs.com — Agency demo (projects)
# ananya@ascentcircle.in — Mentor demo (mentees)
DEFAULT_USER_EMAIL=priya@greenhope.org

# Groq API for AI features (optional — sensible fallbacks run without it)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Dangerous: only for local dev behind a trusted proxy; never expose publicly
TRUST_X_USER_ID=false

# App URLs
APP_BASE_URL=http://127.0.0.1:8000
FRONTEND_BASE_URL=http://127.0.0.1:5500

# Integration encryption key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# Google OAuth (Gmail + Calendar)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/integrations/google/callback
GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/calendar.readonly https://www.googleapis.com/auth/userinfo.email openid

# WhatsApp Cloud API
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
