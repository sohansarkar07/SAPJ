# ── AI ────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=1024

# ── App ───────────────────────────────────────────────────
DATABASE_URL=sqlite:///./second_brain.db
CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:8000,http://localhost:8000
DEFAULT_USER_EMAIL=priya@greenhope.org
TRUST_X_USER_ID=false
APP_BASE_URL=http://127.0.0.1:8000
FRONTEND_BASE_URL=http://127.0.0.1:5500

# Integration encryption key (generate with Fernet.generate_key())
ENCRYPTION_KEY=

# ── Google OAuth (Gmail + Calendar) ───────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/integrations/google/callback
GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/calendar.readonly https://www.googleapis.com/auth/userinfo.email openid

# ── WhatsApp Cloud API ────────────────────────────────────
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
